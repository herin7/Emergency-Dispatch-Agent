API_BASE_URL=https://integrate.api.nvidia.com/v1

# Model name
# Examples:
# mistralai/mistral-nemotron
# mistralai/Mixtral-8x7B-Instruct-v0.1
MODEL_NAME=mistralai/mistral-nemotron

# API Key (DO NOT COMMIT REAL VALUE)
HF_TOKEN="your_token"

# Optional: run all tasks by default, or one of easy|medium|hard
EMERGENCY_DISPATCH_TASK=all

# Optional: only needed when using OpenEnv from_docker_image()
LOCAL_IMAGE_NAME=emergency-dispatch
